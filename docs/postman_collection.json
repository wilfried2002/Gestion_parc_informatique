{
    "info": {
        "name": "Gestion Parc Informatique API",
        "description": "Collection complète pour l'API de gestion de parc informatique Laravel/JWT",
        "version": "1.0.0",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
        { "key": "token",    "value": "",                          "type": "string" }
    ],
    "item": [

        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/auth/login",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@gestion-it.local\",\n  \"password\": \"Admin@123!\"\n}"
                        }
                    },
                    "event": [{
                        "listen": "test",
                        "script": {
                            "exec": ["const r = pm.response.json();", "if(r.data?.access_token) pm.collectionVariables.set('token', r.data.access_token);"]
                        }
                    }]
                },
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/auth/register",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Nouvel Utilisateur\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"department\": \"Marketing\"\n}"
                        }
                    }
                },
                {
                    "name": "Me (profil)",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/auth/me",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Refresh Token",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/auth/refresh",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/auth/logout",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                }
            ]
        },

        {
            "name": "Dashboard",
            "item": [
                {
                    "name": "Statistiques",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/dashboard/stats",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                }
            ]
        },

        {
            "name": "Tickets",
            "item": [
                {
                    "name": "Liste tickets (avec filtres)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw":   "{{base_url}}/tickets?status=open&priority=high&per_page=10",
                            "query": [
                                {"key": "status",   "value": "open"},
                                {"key": "priority", "value": "high"},
                                {"key": "search",   "value": ""},
                                {"key": "per_page", "value": "10"}
                            ]
                        },
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Créer un ticket",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/tickets",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Ordinateur ne démarre plus\",\n  \"description\": \"Mon PC du bureau ne démarre plus depuis ce matin. L'écran reste noir au démarrage.\",\n  \"priority\": \"high\",\n  \"category\": \"hardware\"\n}"
                        }
                    }
                },
                {
                    "name": "Détail ticket",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/tickets/1",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Assigner un ticket (Admin)",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/tickets/1/assign",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"technician_id\": 2\n}"
                        }
                    }
                },
                {
                    "name": "Changer statut ticket",
                    "request": {
                        "method": "PATCH",
                        "url":    "{{base_url}}/tickets/1/status",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"in_progress\"\n}"
                        }
                    }
                },
                {
                    "name": "Upload pièce jointe (ticket)",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/tickets/1/attachments",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
                        "body": {
                            "mode": "formdata",
                            "formdata": [{"key": "file", "type": "file", "src": "/chemin/vers/fichier.pdf"}]
                        }
                    }
                }
            ]
        },

        {
            "name": "Interventions",
            "item": [
                {
                    "name": "Liste interventions",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/interventions?status=planned",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Créer une intervention",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/interventions",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"ticket_id\": 1,\n  \"description\": \"Diagnostic complet du PC, remplacement du disque dur défaillant.\",\n  \"start_date\": \"2024-06-01 09:00:00\"\n}"
                        }
                    }
                },
                {
                    "name": "Démarrer intervention",
                    "request": {
                        "method": "PATCH",
                        "url":    "{{base_url}}/interventions/1/start",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Clôturer intervention",
                    "request": {
                        "method": "PATCH",
                        "url":    "{{base_url}}/interventions/1/complete",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"report\": \"Diagnostic effectué : disque dur défaillant. Remplacement par un SSD 512GB. Tests concluants, PC fonctionnel.\"\n}"
                        }
                    }
                }
            ]
        },

        {
            "name": "Stock",
            "item": [
                {
                    "name": "Liste stock",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/stocks?category=ordinateur",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Créer matériel (Admin)",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/stocks",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"MacBook Pro 14\",\n  \"reference\": \"APPLE-MBP14-2024\",\n  \"category\": \"ordinateur\",\n  \"quantity\": 5,\n  \"quantity_min\": 1,\n  \"brand\": \"Apple\",\n  \"model\": \"MacBook Pro 14\",\n  \"purchase_price\": 2499.00,\n  \"location\": \"Armoire B - Rack 3\"\n}"
                        }
                    }
                },
                {
                    "name": "Affecter matériel (Admin)",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/stocks/1/assign",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"user_id\": 3,\n  \"quantity\": 1,\n  \"notes\": \"Attribution pour télétravail\"\n}"
                        }
                    }
                },
                {
                    "name": "Retour matériel (Admin)",
                    "request": {
                        "method": "PATCH",
                        "url":    "{{base_url}}/stocks/affectations/1/return",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Alertes stock faible (Admin)",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/stocks/low-stock",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                }
            ]
        },

        {
            "name": "Utilisateurs (Admin)",
            "item": [
                {
                    "name": "Liste utilisateurs",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/users?role_id=2",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Liste techniciens",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/users/technicians",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Créer utilisateur",
                    "request": {
                        "method": "POST",
                        "url":    "{{base_url}}/users",
                        "header": [
                            {"key": "Authorization", "value": "Bearer {{token}}"},
                            {"key": "Content-Type",  "value": "application/json"}
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"role_id\": 2,\n  \"name\": \"Nouveau Technicien\",\n  \"email\": \"tech2@gestion-it.local\",\n  \"password\": \"Tech@123!\",\n  \"password_confirmation\": \"Tech@123!\",\n  \"department\": \"Support IT\"\n}"
                        }
                    }
                },
                {
                    "name": "Activer/Désactiver utilisateur",
                    "request": {
                        "method": "PATCH",
                        "url":    "{{base_url}}/users/3/toggle-active",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                }
            ]
        },

        {
            "name": "Pièces jointes",
            "item": [
                {
                    "name": "Télécharger fichier",
                    "request": {
                        "method": "GET",
                        "url":    "{{base_url}}/attachments/1/download",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                },
                {
                    "name": "Supprimer fichier",
                    "request": {
                        "method": "DELETE",
                        "url":    "{{base_url}}/attachments/1",
                        "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
                    }
                }
            ]
        }
    ]
}
